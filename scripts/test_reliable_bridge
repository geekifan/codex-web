#!/usr/bin/env node

const assert = require("node:assert/strict");
const { EventEmitter } = require("node:events");
const test = require("node:test");
const {
  BridgeFrameType,
  decodeBridgeFrame,
  encodeBridgeFrame,
  encodeBridgeValue,
  decodeBridgeValue,
} = require("../src/shared/bridge-protocol.js");
const { ReliableBridgeSession } = require("../src/server/reliable-bridge.js");

class FakeSocket extends EventEmitter {
  readyState = 1;
  sent = [];

  send(payload) {
    this.sent.push(decodeBridgeFrame(new Uint8Array(payload)));
  }

  close() {
    if (this.readyState === 3) {
      return;
    }
    this.readyState = 3;
    this.emit("close");
  }

  terminate() {
    this.close();
  }

  receive(frame) {
    this.emit("message", Buffer.from(encodeBridgeFrame(frame)), true);
  }
}

function createSession(received, options = {}) {
  let disposed = false;
  const session = new ReliableBridgeSession({
    connectionId: "connection-a",
    serverEpoch: "epoch-a",
    graceTimeMs: 60_000,
    ...options,
    onDispose: () => {
      disposed = true;
    },
    onMessage: (message) => {
      received.push(message);
    },
  });
  return { session, isDisposed: () => disposed };
}

function dataFrames(socket) {
  return socket.sent
    .filter((frame) => frame.type === BridgeFrameType.Regular)
    .map((frame) => ({
      id: frame.id,
      ack: frame.ack,
      message: frame.payload,
    }));
}

function regular(id, ack, payload) {
  return { type: BridgeFrameType.Regular, id, ack, payload };
}

function ack(value) {
  return { type: BridgeFrameType.Ack, id: 0, ack: value };
}

test("binary codec preserves nested Uint8Array values", () => {
  const input = {
    text: "hello 世界",
    bytes: new Uint8Array([0, 1, 127, 255]),
    nested: [undefined, null, true, 1.5],
  };
  assert.deepEqual(decodeBridgeValue(encodeBridgeValue(input)), input);
});

test("replays unacknowledged server messages after socket replacement", () => {
  const { session } = createSession([]);
  const firstSocket = new FakeSocket();
  session.attach(firstSocket);
  session.send({ value: "one" });
  firstSocket.close();
  session.send({ value: "two" });

  const secondSocket = new FakeSocket();
  session.attach(secondSocket);

  assert.deepEqual(dataFrames(secondSocket), [
    { id: 1, ack: 0, message: { value: "one" } },
    { id: 2, ack: 0, message: { value: "two" } },
  ]);

  secondSocket.receive(ack(2));
  secondSocket.close();
  const thirdSocket = new FakeSocket();
  session.attach(thirdSocket);
  assert.deepEqual(dataFrames(thirdSocket), []);
  session.dispose("test complete");
});

test("deduplicates replayed client messages", () => {
  const received = [];
  const { session } = createSession(received);
  const firstSocket = new FakeSocket();
  session.attach(firstSocket);
  firstSocket.receive(regular(1, 0, { value: "one" }));
  firstSocket.close();

  const secondSocket = new FakeSocket();
  session.attach(secondSocket);
  secondSocket.receive(regular(1, 0, { value: "one" }));
  secondSocket.receive(regular(2, 0, { value: "two" }));

  assert.deepEqual(received, [{ value: "one" }, { value: "two" }]);
  session.dispose("test complete");
});

test("requests replay when a client message has a gap", () => {
  const received = [];
  const { session } = createSession(received);
  const socket = new FakeSocket();
  session.attach(socket);
  socket.receive(regular(2, 0, { value: "two" }));

  assert.deepEqual(received, []);
  assert.deepEqual(socket.sent.at(-1), {
    type: BridgeFrameType.ReplayRequest,
    id: 0,
    ack: 0,
  });
  session.dispose("test complete");
});

test("keeps the replacement socket alive when taking over", () => {
  const received = [];
  const { session, isDisposed } = createSession(received);
  const firstSocket = new FakeSocket();
  const secondSocket = new FakeSocket();
  session.attach(firstSocket);
  session.attach(secondSocket);

  secondSocket.receive(regular(1, 0, { value: "active" }));

  assert.equal(firstSocket.readyState, 3);
  assert.equal(secondSocket.readyState, 1);
  assert.equal(isDisposed(), false);
  assert.deepEqual(received, [{ value: "active" }]);
  session.dispose("test complete");
});

test("limits replay to an acknowledgement-driven send window", () => {
  const { session } = createSession([], { maxInFlightBytes: 100 });
  const firstSocket = new FakeSocket();
  session.attach(firstSocket);
  firstSocket.close();
  session.send({ value: "a".repeat(60) });
  session.send({ value: "b".repeat(60) });
  session.send({ value: "c".repeat(60) });

  const secondSocket = new FakeSocket();
  session.attach(secondSocket);
  assert.deepEqual(
    dataFrames(secondSocket).map((frame) => frame.id),
    [1],
  );

  secondSocket.receive(ack(1));
  assert.deepEqual(
    dataFrames(secondSocket).map((frame) => frame.id),
    [1, 2],
  );

  secondSocket.receive(ack(2));
  assert.deepEqual(
    dataFrames(secondSocket).map((frame) => frame.id),
    [1, 2, 3],
  );
  session.dispose("test complete");
});

test("sendAndWait resolves only after acknowledgement", async () => {
  const { session } = createSession([]);
  const socket = new FakeSocket();
  session.attach(socket);
  let resolved = false;
  const pending = session.sendAndWait({ bytes: new Uint8Array([1, 2, 3]) });
  pending.then(() => {
    resolved = true;
  });
  await Promise.resolve();
  assert.equal(resolved, false);
  socket.receive(ack(1));
  await pending;
  assert.equal(resolved, true);
  session.dispose("test complete");
});
