#!/usr/bin/env node

const assert = require("node:assert/strict");
const fs = require("node:fs/promises");
const os = require("node:os");
const path = require("node:path");
const test = require("node:test");
const { EventEmitter } = require("node:events");
const {
  WorkspaceFileManager,
  workspaceFileEtag,
} = require("../src/server/workspace-files.js");
const {
  WORKSPACE_FILE_CHUNK_BYTES,
} = require("../src/shared/workspace-files.js");
const {
  BridgeFrameType,
  decodeBridgeFrame,
  encodeBridgeFrame,
} = require("../src/shared/bridge-protocol.js");
const { ReliableBridgeSession } = require("../src/server/reliable-bridge.js");

class FakeSocket extends EventEmitter {
  readyState = 1;
  sent = [];

  send(payload) {
    this.sent.push(decodeBridgeFrame(new Uint8Array(payload)));
  }

  receive(frame) {
    this.emit("message", Buffer.from(encodeBridgeFrame(frame)), true);
  }

  close() {
    if (this.readyState !== 3) {
      this.readyState = 3;
      this.emit("close");
    }
  }

  terminate() {
    this.close();
  }
}

class MessageSink {
  messages = [];
  waiters = [];

  send = (message) => {
    this.messages.push(message);
    for (const waiter of [...this.waiters]) {
      if (waiter.predicate(message)) {
        this.waiters.splice(this.waiters.indexOf(waiter), 1);
        waiter.resolve(message);
      }
    }
    return Promise.resolve();
  };

  waitFor(predicate) {
    const existing = this.messages.find(predicate);
    if (existing) {
      return Promise.resolve(existing);
    }
    return new Promise((resolve, reject) => {
      const timer = setTimeout(() => {
        reject(new Error("timed out waiting for workspace file message"));
      }, 5_000);
      this.waiters.push({
        predicate,
        resolve: (message) => {
          clearTimeout(timer);
          resolve(message);
        },
      });
    });
  }
}

async function fixture(t) {
  const directory = await fs.mkdtemp(
    path.join(os.tmpdir(), "codex-web-files-"),
  );
  t.after(() => fs.rm(directory, { recursive: true, force: true }));
  const sink = new MessageSink();
  const manager = new WorkspaceFileManager(sink.send);
  t.after(() => manager.dispose());
  return { directory, manager, sink };
}

test("streams text reads in bounded binary chunks", async (t) => {
  const { directory, manager, sink } = await fixture(t);
  const filePath = path.join(directory, "large.txt");
  const content = Buffer.from("世界\n".repeat(100_000));
  await fs.writeFile(filePath, content);

  manager.handle({
    type: "workspace-file-read-request",
    requestId: "read-1",
    hostId: "local",
    path: filePath,
    representation: "auto",
  });
  await sink.waitFor(
    (message) =>
      message.type === "workspace-file-read-end" &&
      message.requestId === "read-1",
  );

  const start = sink.messages.find(
    (message) => message.type === "workspace-file-read-start",
  );
  const chunks = sink.messages.filter(
    (message) => message.type === "workspace-file-read-chunk",
  );
  assert.equal(start.representation, "text");
  assert.ok(chunks.length > 1);
  assert.ok(
    chunks.every(
      (message) => message.bytes.byteLength <= WORKSPACE_FILE_CHUNK_BYTES,
    ),
  );
  assert.deepEqual(
    Buffer.concat(chunks.map((message) => Buffer.from(message.bytes))),
    content,
  );
});

test("writes through a temporary file and returns a new etag", async (t) => {
  const { directory, manager, sink } = await fixture(t);
  const filePath = path.join(directory, "edit.txt");
  await fs.writeFile(filePath, "before");
  const ifMatch = workspaceFileEtag(await fs.stat(filePath));
  const bytes = Buffer.from("after".repeat(100_000));

  manager.handle({
    type: "workspace-file-write-start",
    requestId: "write-1",
    transferId: "transfer-1",
    hostId: "local",
    path: filePath,
    ifMatch,
    byteLength: bytes.byteLength,
  });
  await sink.waitFor(
    (message) => message.type === "workspace-file-write-ready",
  );
  for (
    let offset = 0;
    offset < bytes.byteLength;
    offset += WORKSPACE_FILE_CHUNK_BYTES
  ) {
    manager.handle({
      type: "workspace-file-write-chunk",
      requestId: "write-1",
      transferId: "transfer-1",
      offset,
      bytes: bytes.subarray(offset, offset + WORKSPACE_FILE_CHUNK_BYTES),
    });
    await sink.waitFor(
      (message) =>
        message.type === "workspace-file-write-chunk-result" &&
        message.offset === offset,
    );
  }
  manager.handle({
    type: "workspace-file-write-commit",
    requestId: "write-1",
    transferId: "transfer-1",
  });
  const result = await sink.waitFor(
    (message) => message.type === "workspace-file-write-result",
  );

  assert.equal(result.outcome, "saved");
  assert.notEqual(result.etag, ifMatch);
  assert.deepEqual(await fs.readFile(filePath), bytes);
});

test("detects a commit conflict without overwriting the external edit", async (t) => {
  const { directory, manager, sink } = await fixture(t);
  const filePath = path.join(directory, "conflict.txt");
  await fs.writeFile(filePath, "before");
  const ifMatch = workspaceFileEtag(await fs.stat(filePath));
  const bytes = Buffer.from("our edit");

  manager.handle({
    type: "workspace-file-write-start",
    requestId: "write-conflict",
    transferId: "transfer-conflict",
    hostId: "local",
    path: filePath,
    ifMatch,
    byteLength: bytes.byteLength,
  });
  await sink.waitFor(
    (message) => message.type === "workspace-file-write-ready",
  );
  manager.handle({
    type: "workspace-file-write-chunk",
    requestId: "write-conflict",
    transferId: "transfer-conflict",
    offset: 0,
    bytes,
  });
  await sink.waitFor(
    (message) => message.type === "workspace-file-write-chunk-result",
  );
  await fs.writeFile(filePath, "external edit");
  manager.handle({
    type: "workspace-file-write-commit",
    requestId: "write-conflict",
    transferId: "transfer-conflict",
  });
  const result = await sink.waitFor(
    (message) =>
      message.type === "workspace-file-write-result" &&
      message.requestId === "write-conflict",
  );

  assert.equal(result.outcome, "conflict");
  assert.equal(await fs.readFile(filePath, "utf8"), "external edit");
  assert.deepEqual(
    (await fs.readdir(directory)).filter((name) =>
      name.includes("codex-web-save"),
    ),
    [],
  );
});

test("disposing a session removes unfinished temporary files", async (t) => {
  const { directory, manager, sink } = await fixture(t);
  const filePath = path.join(directory, "dispose.txt");
  await fs.writeFile(filePath, "before");
  manager.handle({
    type: "workspace-file-write-start",
    requestId: "write-dispose",
    transferId: "transfer-dispose",
    hostId: "local",
    path: filePath,
    ifMatch: workspaceFileEtag(await fs.stat(filePath)),
    byteLength: 10,
  });
  await sink.waitFor(
    (message) => message.type === "workspace-file-write-ready",
  );
  await manager.dispose();
  assert.deepEqual(
    (await fs.readdir(directory)).filter((name) =>
      name.includes("codex-web-save"),
    ),
    [],
  );
  assert.equal(await fs.readFile(filePath, "utf8"), "before");
});

test("a read resumes through reliable replay without duplicating chunks", async (t) => {
  const directory = await fs.mkdtemp(
    path.join(os.tmpdir(), "codex-web-replay-"),
  );
  t.after(() => fs.rm(directory, { recursive: true, force: true }));
  const filePath = path.join(directory, "replay.bin");
  const content = Buffer.alloc(WORKSPACE_FILE_CHUNK_BYTES * 2 + 17, 0x5a);
  await fs.writeFile(filePath, content);

  let manager;
  const session = new ReliableBridgeSession({
    connectionId: "workspace-replay",
    serverEpoch: "epoch",
    graceTimeMs: 60_000,
    onDispose: () => void manager?.dispose(),
    onMessage: (message) => manager.handle(message),
  });
  manager = new WorkspaceFileManager((message, wait) =>
    wait ? session.sendAndWait(message) : session.send(message),
  );
  t.after(() => session.dispose("test complete"));

  const firstSocket = new FakeSocket();
  session.attach(firstSocket);
  firstSocket.receive({
    type: BridgeFrameType.Regular,
    id: 1,
    ack: 0,
    payload: {
      type: "workspace-file-read-request",
      requestId: "replay-read",
      hostId: "local",
      path: filePath,
      representation: "blob",
    },
  });

  await waitUntil(() => regularFrames(firstSocket).length >= 1);
  const start = regularFrames(firstSocket)[0];
  assert.equal(start.payload.type, "workspace-file-read-start");
  firstSocket.receive({
    type: BridgeFrameType.Ack,
    id: 0,
    ack: start.id,
  });
  await waitUntil(() => regularFrames(firstSocket).length >= 2);
  const firstChunk = regularFrames(firstSocket)[1];
  assert.equal(firstChunk.payload.type, "workspace-file-read-chunk");

  const seenIds = new Set([start.id, firstChunk.id]);
  const chunks = [Buffer.from(firstChunk.payload.bytes)];
  firstSocket.close();
  const secondSocket = new FakeSocket();
  session.attach(secondSocket);
  await waitUntil(() => regularFrames(secondSocket).length >= 1);
  assert.equal(regularFrames(secondSocket)[0].id, firstChunk.id);
  secondSocket.receive({
    type: BridgeFrameType.Ack,
    id: 0,
    ack: firstChunk.id,
  });

  let completed = false;
  while (!completed) {
    await waitUntil(() =>
      regularFrames(secondSocket).some((frame) => !seenIds.has(frame.id)),
    );
    for (const frame of regularFrames(secondSocket)) {
      if (seenIds.has(frame.id)) {
        continue;
      }
      seenIds.add(frame.id);
      if (frame.payload.type === "workspace-file-read-chunk") {
        chunks.push(Buffer.from(frame.payload.bytes));
      }
      if (frame.payload.type === "workspace-file-read-end") {
        completed = true;
      }
      secondSocket.receive({
        type: BridgeFrameType.Ack,
        id: 0,
        ack: frame.id,
      });
    }
  }

  assert.deepEqual(Buffer.concat(chunks), content);
});

function regularFrames(socket) {
  return socket.sent.filter((frame) => frame.type === BridgeFrameType.Regular);
}

async function waitUntil(predicate) {
  const deadline = Date.now() + 5_000;
  while (!predicate()) {
    if (Date.now() > deadline) {
      throw new Error("timed out waiting for condition");
    }
    await new Promise((resolve) => setTimeout(resolve, 5));
  }
}
